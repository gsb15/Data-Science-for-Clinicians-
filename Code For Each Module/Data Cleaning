########################################
#Extracting specific words from a string
##########################################

#The notes variable has a lot of words, and even paragraphs.
#This is not tenable to perform basic analyses, on body parts or injuries, etc. 
#We must extract specific words from these notes to create new variables for analyses. 
#Will use the stringr package. 

#We will create a new variable, looking at any knee injury. 


# Define stems to match for different types of knee injuries: Remember, this is case specific, even for the stem!
stems <- c("kne", "menisc", "patell", "ACL", "PCL", "MCL", "Cruciate")

# Create regex pattern
pattern <- paste0("\\b(", paste(stems, collapse = "|"), ")\\w*\\b") 
#b starts the words, stems in the middle, w* equates parts of strings beyond the stems, b closes the search

# Extract matching words from 'notes' column
four_sports_injury <- four_sports_injury %>%
  mutate(knee_injury_terms = str_extract_all(notes, regex(pattern, ignore_case = TRUE))) 
#Want to extract ANY matching words
#ignore_case = TRUE, allows for both upper and lower cases for string matches

#Checking 

four_sports_injury %>% 
  count(knee_injury_terms)
#OK, we see a lot of different combinations, with over 5,000 rows
#A lot of knee injuries. 

typeof(four_sports_injury$knee_injury_terms) #list currently, will make to character
four_sports_injury$knee_injury_terms <- sapply(four_sports_injury$knee_injury_terms, toString) #notice the sapply again here :)



##Let's do a random check of the data here to see how well we extracted knee injury 

four_sports_injury %>% 
  select(date, team, relinquished, notes, knee_injury_terms) %>% 
  View() #Looks pretty goot 

#Let's filter to just knee injuries now 

four_sports_injury %>% 
  filter(knee_injury_terms != "") %>% #Logic saying we don't want blank knnee injury character cells
  select(date, team, relinquished, notes, knee_injury_terms) %>% 
  View()
#Looks good!



#Let's know make a knee injury variable

four_sports_injury <- four_sports_injury %>% 
  mutate(knee_injury_binary = ifelse(knee_injury_terms == "", #This is delineating a blank character, aka no knee injury within the notes
                                     0, 
